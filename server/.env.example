PORT=5000
NODE_ENV=production

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/samakaab
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
CORS_ORIGIN=https://app.samkab.com

# Public URLs (no trailing slash)
FRONTEND_URL=https://app.samkab.com
PUBLIC_API_URL=https://your-api.onrender.com

# OneDrive backup (Azure App registration — see Settings in app)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=https://your-api.onrender.com/api/backup/onedrive/callback

# Random secret for cron-job.org weekly/monthly auto-upload
BACKUP_CRON_SECRET=replace-with-long-random-string
