# Copy to .env and fill in values
PORT=5000
NODE_ENV=development

# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/samakaab

# Required in production — use a long random string (32+ characters)
JWT_SECRET=change-me-to-a-long-random-secret

# Your live frontend URL(s), comma-separated — must match exactly (https, no trailing slash)
# Example for custom domain:
CORS_ORIGIN=https://app.samkab.com
