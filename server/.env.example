# Copy to .env and fill in values
PORT=5000
NODE_ENV=development

# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/samakaab

# Required in production — use a long random string (32+ characters)
JWT_SECRET=change-me-to-a-long-random-secret

# Comma-separated frontend URLs allowed to call the API (required in production)
# Example: https://your-app.vercel.app,https://www.yourdomain.com
CORS_ORIGIN=http://localhost:5173
